# Database
DATABASE_URL="postgresql://user:password@localhost:5432/phdradar"
DIRECT_URL="postgresql://user:password@localhost:5432/phdradar"

# Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-generate-with-openssl-rand-base64-32"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# AI
ANTHROPIC_API_KEY="sk-ant-..."
OPENAI_API_KEY="sk-..."

# Data Sources
# ------------------------------------------------------------------
# FREE — no key needed. These work out of the box:
#   OpenAlex, ArXiv, CrossRef, CSRankings, DBLP, ORCID,
#   GitHub (60 req/hr), Medium (RSS), NSF Awards, NIH Reporter
# ------------------------------------------------------------------
# Polite-pool identification — used as contact email in User-Agent for
# OpenAlex and CrossRef so they don't rate-limit us. Uses EMAIL_FROM
# if blank. Not required but strongly recommended.
OPENALEX_MAILTO=""
CROSSREF_MAILTO=""
# GitHub personal access token — optional; bumps rate limit from 60/hr to 5000/hr
GITHUB_TOKEN=""
# Semantic Scholar API key — optional; raises the rate limit
SEMANTIC_SCHOLAR_API_KEY=""
# ------------------------------------------------------------------
# PAID — optional upgrades. Everything works without these.
# ------------------------------------------------------------------
# SerpApi — adds Google Scholar profile + article fetches.
# OpenAlex already covers ~95% of Scholar for free. https://serpapi.com
SERPAPI_KEY=""
# ProxyCurl — only legal way to pull LinkedIn profile data.
# If blank, enrichment pulls bio/affiliations from ORCID + faculty
# page instead. https://nubela.co/proxycurl
PROXYCURL_API_KEY=""

# Vector DB
PINECONE_API_KEY=""
PINECONE_INDEX="phdradar-papers"

# Cache
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Search
TYPESENSE_API_KEY=""
TYPESENSE_HOST=""

# Monitoring
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_POSTHOG_KEY=""

# Storage (optional — falls back to local public/uploads/ in dev)
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_KEY=""
SUPABASE_STORAGE_BUCKET="user-uploads"

# Payments
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_PRO="price_pro"
STRIPE_PRICE_PREMIUM="price_premium"

# Email
RESEND_API_KEY=""
EMAIL_FROM="notifications@phdradar.com"

# Cron Jobs (protects notification endpoints)
CRON_SECRET="generate-a-random-secret-here"
